# ============================================
# PaperBanana Web 前端环境变量模板
# ============================================
# 使用方法:
#   1. 本地开发:复制本文件为 .env.local,填入实际值
#   2. 线上部署:通过 GitHub Actions secrets 或部署平台注入
#   3. .env.local 已在 .gitignore 中,不会进入 git
#
# ⚠️ 安全警告:
#   VITE_* 开头的变量会被 Vite 打包进网页 JS,
#   是公开可见的,绝不可放任何密钥、Token、
#   数据库连接串、API key 等敏感信息。
#   敏感信息只能放在后端(auth-gateway / Laf 函数)。
# ============================================

# 后端模式
# gateway: 通过 auth-gateway 统一转发(推荐)
# direct: 直连 Laf
VITE_BACKEND_MODE=gateway

# 后端 API 基础地址(指向 auth-gateway)
VITE_API_BASE=https://yifbnnzrwmxn.sealoshzh.site

# 是否启用登录功能
VITE_AUTH_ENABLED=true

# better-auth 服务地址
VITE_AUTH_BASE=https://yifbnnzrwmxn.sealoshzh.site

# 部署的 base path
# 根路径部署用 /,部署到子路径(如 /paperbanana/)时改这里
VITE_BASE_PATH=/
