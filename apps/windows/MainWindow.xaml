<Window
    x:Class="PaperBanana.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PaperBanana">

    <Grid Background="#FFF3F2EE">
        <Grid.Resources>
            <SolidColorBrush x:Key="PaperBrush" Color="#FFF3F2EE" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFB" />
            <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF3F2EC" />
            <SolidColorBrush x:Key="HairlineBrush" Color="#FFD9D6CC" />
            <SolidColorBrush x:Key="HairlineStrongBrush" Color="#FFC8C2B6" />
            <SolidColorBrush x:Key="InkBrush" Color="#FF171513" />
            <SolidColorBrush x:Key="InkSoftBrush" Color="#FF343230" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FF68706D" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FFB98518" />
            <SolidColorBrush x:Key="AccentWashBrush" Color="#FFFFF3D2" />
            <SolidColorBrush x:Key="SageWashBrush" Color="#FFEDF5EF" />
            <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#FF171513" />
            <SolidColorBrush x:Key="DisabledButtonBrush" Color="#FFC9C0B2" />

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            </Style>
            <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource InkSoftBrush}" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,14"
                Padding="28,20"
                CornerRadius="22"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                Background="{StaticResource SurfaceBrush}">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            CornerRadius="18"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1">
                        <Image Source="Assets/icon.png" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Spacing="7" VerticalAlignment="Center">
                        <TextBlock Text="PaperBanana 工作台"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Padding="10,3" CornerRadius="8" Background="{StaticResource SageWashBrush}" BorderBrush="#FFC8D8CC" BorderThickness="1">
                                <TextBlock Text="多智能体" FontSize="11" FontWeight="SemiBold" Foreground="#FF315F51" />
                            </Border>
                            <Border Padding="10,3" CornerRadius="8" Background="{StaticResource AccentWashBrush}" BorderBrush="#FFEAD28D" BorderThickness="1">
                                <TextBlock Text="学术图示生成" FontSize="11" FontWeight="SemiBold" Foreground="#FF6B4807" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Padding="12,7"
                            CornerRadius="11"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="HealthText"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Border>
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="15" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AuthButton" Click="AuthButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE77B;" FontSize="15" />
                            <TextBlock Text="登录 / 注册" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20,0,20,18"
                Padding="4"
                HorizontalAlignment="Left"
                CornerRadius="14"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                Background="#BFFFFFFB">
            <StackPanel Orientation="Horizontal" Spacing="0">
                <Button x:Name="GenerateTabButton"
                        MinWidth="120"
                        Background="{StaticResource SurfaceBrush}"
                        BorderThickness="0"
                        Content="生成候选图"
                        Click="GenerateTabButton_Click" />
                <Button x:Name="RecordsTabButton"
                        MinWidth="108"
                        BorderThickness="0"
                        Content="任务记录"
                        Click="RecordsTabButton_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="GeneratePanel" Grid.Row="2" Padding="20,0,20,24" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="22"
                        CornerRadius="20"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                            <StackPanel>
                                <TextBlock Text="生成设置" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="选择模型平台并粘贴 API 密钥。" Style="{StaticResource SectionSubtitleStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <InfoBar x:Name="SubmitInfoBar" IsOpen="False" Severity="Error" />

                        <StackPanel Spacing="8">
                            <TextBlock Text="使用模式" Style="{StaticResource FieldLabelStyle}" />
                            <Border Padding="5"
                                    CornerRadius="16"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1">
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="9" Background="{StaticResource SurfaceBrush}">
                                        <RadioButton x:Name="SimpleModeRadio"
                                                     Content="普通模式&#x0a;平台 + Key"
                                                     GroupName="Mode"
                                                     IsChecked="True"
                                                     HorizontalAlignment="Center"
                                                     Checked="ModeRadio_Checked" />
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="9">
                                        <RadioButton x:Name="AdvancedModeRadio"
                                                     Content="专业模式&#x0a;模型与流程"
                                                     GroupName="Mode"
                                                     HorizontalAlignment="Center"
                                                     Checked="ModeRadio_Checked" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <ComboBox x:Name="ProviderComboBox"
                                  Header="模型平台"
                                  DisplayMemberPath="Label"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ProviderComboBox_SelectionChanged" />

                        <Border Padding="14"
                                CornerRadius="16"
                                Background="#BFFFFFFB"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D7;" FontSize="16" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="API 密钥" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                                <TextBlock Text="无需填写全部密钥，只填当前选中的模型接口即可。"
                                           Style="{StaticResource SectionSubtitleStyle}" />
                                <PasswordBox x:Name="ApiKeyBox"
                                             Header="当前平台 API Key"
                                             PasswordChanged="ApiKeyBox_PasswordChanged" />
                                <TextBlock x:Name="GuideText"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="SimpleSummaryPanel"
                                Padding="12"
                                CornerRadius="14"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="SimpleSummaryText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel x:Name="AdvancedPanel" Spacing="12">
                            <ComboBox x:Name="MainModelComboBox" Header="主模型" DisplayMemberPath="DisplayName" />
                            <ComboBox x:Name="ImageModelComboBox" Header="图像生成模型" DisplayMemberPath="DisplayName" />
                            <ComboBox x:Name="PipelineComboBox" Header="生成流程" DisplayMemberPath="Label" />
                            <ComboBox x:Name="RetrievalComboBox" Header="检索设置" DisplayMemberPath="Label" />
                            <ComboBox x:Name="AspectRatioComboBox" Header="画面比例" DisplayMemberPath="Label" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CandidateComboBox" Header="候选图数量" DisplayMemberPath="Label" />
                                <ComboBox x:Name="CriticRoundComboBox" Grid.Column="1" Header="评审轮数" DisplayMemberPath="Label" />
                            </Grid>
                            <CheckBox x:Name="MockCheckBox" Content="模拟模式" />
                        </StackPanel>

                        <Button x:Name="SubmitButton"
                                Content="生成候选图"
                                MinHeight="42"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource PrimaryButtonBrush}"
                                Foreground="White"
                                Click="SubmitButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="24"
                        CornerRadius="20"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*" />
                            <ColumnDefinition Width="5*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8A5;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                                <StackPanel>
                                    <TextBlock Text="输入内容" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="选择信息图类别，再粘贴论文方法部分和目标图注。" Style="{StaticResource SectionSubtitleStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Padding="13"
                                    CornerRadius="16"
                                    Background="#9FF3F2EC"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <FontIcon Glyph="&#xE70F;" FontSize="16" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="快速上手案例" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                                    </StackPanel>
                                    <ItemsControl x:Name="ExamplesItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="210" MinHeight="92" Margin="0,0,8,8" Click="ExampleButton_Click" Tag="{Binding}">
                                                    <StackPanel Spacing="5">
                                                        <Border Padding="7,3" HorizontalAlignment="Left" CornerRadius="8" Background="{StaticResource AccentWashBrush}" BorderBrush="#FFEAD28D" BorderThickness="1">
                                                            <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="#FF77510B" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Hint}" FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ComboBox x:Name="CategoryComboBox"
                                      Header="信息图类别"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch" />
                            <TextBox x:Name="MethodContentBox"
                                     Header="论文方法内容"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="150" />
                            <TextBox x:Name="CaptionBox"
                                     Header="目标图注"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="100" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xEB9F;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                                <StackPanel>
                                    <TextBlock Text="生成结果" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock x:Name="CurrentJobText"
                                               Text="提交任务后显示生成结果。"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Border MinHeight="520"
                                    Padding="16"
                                    CornerRadius="18"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource HairlineStrongBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <InfoBar x:Name="JobErrorInfoBar" IsOpen="False" Severity="Error" />
                                    <ListView x:Name="ResultImagesList" MaxHeight="620">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Spacing="8" Padding="0,0,0,16">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <Border Height="240" Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                                                        <Image Source="{Binding PreviewSource}" Stretch="Uniform" />
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button Content="打开" Click="OpenImageButton_Click" Tag="{Binding}" />
                                                        <Button Content="保存" Click="SaveImageButton_Click" Tag="{Binding}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="RecordsPanel" Grid.Row="2" Padding="20,0,20,24" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
            <Border MaxWidth="1120"
                    HorizontalAlignment="Stretch"
                    Padding="24"
                    CornerRadius="20"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1"
                    Background="{StaticResource SurfaceBrush}">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE8A5;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                        <StackPanel>
                            <TextBlock Text="任务记录" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="只显示当前账号的生成任务，失败任务会直接显示模型返回原因。" Style="{StaticResource SectionSubtitleStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <InfoBar x:Name="RecordsInfoBar" IsOpen="False" Severity="Error" />

                    <Border Padding="16"
                            CornerRadius="16"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            Background="#BFFFFFFB">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="AccountText"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkSoftBrush}" />
                                <Button Grid.Column="1" Content="刷新记录" Click="RefreshRecordsButton_Click" />
                            </Grid>

                            <StackPanel x:Name="AuthPanel" Spacing="10">
                                <ComboBox x:Name="AuthModeComboBox" Header="账号操作" SelectionChanged="AuthModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="登录" Tag="sign-in" IsSelected="True" />
                                    <ComboBoxItem Content="注册" Tag="sign-up" />
                                </ComboBox>
                                <TextBox x:Name="AuthNameBox" Header="昵称" PlaceholderText="可选，最多 24 个字" MaxLength="24" Visibility="Collapsed" />
                                <TextBox x:Name="AuthEmailBox" Header="邮箱" PlaceholderText="name@example.com" />
                                <PasswordBox x:Name="AuthPasswordBox" Header="密码" PlaceholderText="至少 8 位" />
                                <Button x:Name="AuthSubmitButton" Content="继续" HorizontalAlignment="Left" Click="AuthSubmitButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="RecordsList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14"
                                        Margin="0,0,0,10"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        Background="{StaticResource SurfaceBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Meta}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StatusLabel}" />
                                        <TextBlock Text="{Binding CreatedText}" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding Images}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="220"
                                                            Margin="0,8,10,0"
                                                            Padding="10"
                                                            CornerRadius="14"
                                                            BorderBrush="{StaticResource HairlineBrush}"
                                                            BorderThickness="1"
                                                            Background="{StaticResource SurfaceMutedBrush}">
                                                        <StackPanel Spacing="8">
                                                            <Border Height="124"
                                                                    CornerRadius="12"
                                                                    Background="{StaticResource SurfaceBrush}">
                                                                <Image Source="{Binding PreviewSource}" Stretch="Uniform" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <Button Content="打开" Click="OpenImageButton_Click" Tag="{Binding}" />
                                                                <Button Content="保存" Click="SaveRecordImageButton_Click" Tag="{Binding}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
