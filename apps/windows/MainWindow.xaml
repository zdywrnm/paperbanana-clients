<Window
    x:Class="PaperBanana.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PaperBanana">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="10" Background="#FFF2B84B">
                        <TextBlock Text="PB" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="#FF3F2B12" />
                    </Border>
                    <StackPanel Spacing="2">
                        <TextBlock Text="PaperBanana Windows" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="原生 WinUI 3 工作台" Opacity="0.72" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock x:Name="HealthText" VerticalAlignment="Center" Opacity="0.78" />
                    <Button x:Name="RefreshButton" Content="刷新" Click="RefreshButton_Click" />
                    <Button x:Name="AuthButton" Content="登录 / 注册" Click="AuthButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" BorderThickness="0,0,1,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <Button x:Name="GenerateTabButton" Content="生成候选图" HorizontalAlignment="Stretch" Click="GenerateTabButton_Click" />
                    <Button x:Name="RecordsTabButton" Content="任务记录" HorizontalAlignment="Stretch" Click="RecordsTabButton_Click" />
                    <Button x:Name="AdminTabButton" Content="站长记录" HorizontalAlignment="Stretch" Click="AdminTabButton_Click" />
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,8" />
                    <TextBox x:Name="ApiBaseBox" Header="后端地址" Text="https://yifbnnzrwmxn.sealoshzh.site" LostFocus="ApiBaseBox_LostFocus" />
                    <Button Content="恢复默认后端" HorizontalAlignment="Stretch" Click="ResetApiBaseButton_Click" />
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="GeneratePanel" Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="16">
                        <TextBlock Text="生成设置" FontSize="22" FontWeight="SemiBold" />

                        <InfoBar x:Name="SubmitInfoBar" IsOpen="False" Severity="Error" />

                        <StackPanel Spacing="8">
                            <TextBlock Text="使用模式" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <RadioButton x:Name="SimpleModeRadio" Content="普通模式" GroupName="Mode" IsChecked="True" Checked="ModeRadio_Checked" />
                                <RadioButton x:Name="AdvancedModeRadio" Content="专业模式" GroupName="Mode" Checked="ModeRadio_Checked" />
                            </StackPanel>
                        </StackPanel>

                        <ComboBox x:Name="ProviderComboBox" Header="模型平台" DisplayMemberPath="Label" SelectionChanged="ProviderComboBox_SelectionChanged" />

                        <StackPanel Spacing="8">
                            <PasswordBox x:Name="ApiKeyBox" Header="API Key" PasswordChanged="ApiKeyBox_PasswordChanged" />
                            <TextBlock x:Name="GuideText" TextWrapping="Wrap" Opacity="0.75" />
                        </StackPanel>

                        <Border x:Name="SimpleSummaryPanel" Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <TextBlock x:Name="SimpleSummaryText" TextWrapping="Wrap" />
                        </Border>

                        <StackPanel x:Name="AdvancedPanel" Spacing="12">
                            <ComboBox x:Name="MainModelComboBox" Header="主模型" DisplayMemberPath="DisplayName" />
                            <ComboBox x:Name="ImageModelComboBox" Header="图像生成模型" DisplayMemberPath="DisplayName" />
                            <ComboBox x:Name="PipelineComboBox" Header="生成流程" DisplayMemberPath="Label" />
                            <ComboBox x:Name="RetrievalComboBox" Header="检索设置" DisplayMemberPath="Label" />
                            <ComboBox x:Name="AspectRatioComboBox" Header="画面比例" DisplayMemberPath="Label" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CandidateComboBox" Header="候选图数量" DisplayMemberPath="Label" />
                                <ComboBox x:Name="CriticRoundComboBox" Grid.Column="1" Header="评审轮数" DisplayMemberPath="Label" />
                            </Grid>
                            <CheckBox x:Name="MockCheckBox" Content="模拟模式" />
                        </StackPanel>

                        <Button x:Name="SubmitButton" Content="生成候选图" HorizontalAlignment="Stretch" Click="SubmitButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="16">
                        <TextBlock Text="输入内容" FontSize="22" FontWeight="SemiBold" />
                        <ItemsControl x:Name="ExamplesItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,8" Click="ExampleButton_Click" Tag="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Hint}" TextWrapping="Wrap" Opacity="0.72" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ComboBox x:Name="CategoryComboBox" Header="信息图类别" DisplayMemberPath="DisplayName" />
                        <TextBox x:Name="MethodContentBox" Header="论文方法内容" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="170" />
                        <TextBox x:Name="CaptionBox" Header="目标图注" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="86" />

                        <Border Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="生成结果" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock x:Name="CurrentJobText" Opacity="0.72" />
                                </StackPanel>
                                <InfoBar x:Name="JobErrorInfoBar" IsOpen="False" Severity="Error" />
                                <ListView x:Name="ResultImagesList" MaxHeight="520">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8" Padding="0,0,0,16">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <Border Height="240" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8">
                                                    <Image Source="{Binding PreviewSource}" Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Content="打开" Click="OpenImageButton_Click" Tag="{Binding}" />
                                                    <Button Content="保存" Click="SaveImageButton_Click" Tag="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <ScrollViewer x:Name="RecordsPanel" Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel Spacing="18">
                    <TextBlock Text="任务记录" FontSize="22" FontWeight="SemiBold" />
                    <InfoBar x:Name="RecordsInfoBar" IsOpen="False" Severity="Error" />
                    <Border Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="AccountText" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="刷新记录" Click="RefreshRecordsButton_Click" />
                            </Grid>

                            <StackPanel x:Name="AuthPanel" Spacing="10">
                                <ComboBox x:Name="AuthModeComboBox" Header="账号操作" SelectionChanged="AuthModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="登录" Tag="sign-in" IsSelected="True" />
                                    <ComboBoxItem Content="注册" Tag="sign-up" />
                                </ComboBox>
                                <TextBox x:Name="AuthNameBox" Header="昵称" PlaceholderText="可选，最多 24 个字" MaxLength="24" Visibility="Collapsed" />
                                <TextBox x:Name="AuthEmailBox" Header="邮箱" PlaceholderText="name@example.com" />
                                <PasswordBox x:Name="AuthPasswordBox" Header="密码" PlaceholderText="至少 8 位" />
                                <Button x:Name="AuthSubmitButton" Content="继续" HorizontalAlignment="Left" Click="AuthSubmitButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="RecordsList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Meta}" Opacity="0.72" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StatusLabel}" />
                                        <TextBlock Text="{Binding CreatedText}" Opacity="0.64" />
                                        <TextBlock Text="{Binding Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AdminPanel" Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel Spacing="18">
                    <TextBlock Text="站长记录" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="输入 ADMIN_TOKEN 查看最近任务、模型选择和失败原因。" Opacity="0.72" />
                    <InfoBar x:Name="AdminInfoBar" IsOpen="False" Severity="Error" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PasswordBox x:Name="AdminTokenBox" Header="ADMIN_TOKEN" Width="320" />
                        <Button Content="刷新" VerticalAlignment="Bottom" Click="RefreshAdminButton_Click" />
                    </StackPanel>
                    <ListView x:Name="AdminList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Meta}" Opacity="0.72" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StatusLabel}" />
                                        <TextBlock Text="{Binding CreatedText}" Opacity="0.64" />
                                        <TextBlock Text="{Binding Error}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
