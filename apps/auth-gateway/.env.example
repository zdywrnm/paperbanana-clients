NODE_ENV=production
PORT=3005

# Public URL of this gateway.
# Current Sealos production URL:
AUTH_BASE_URL=https://yifbnnzrwmxn.sealoshzh.site
# If a custom API domain is added later, change to:
# AUTH_BASE_URL=https://api.paperbanana.asia

FRONTEND_ORIGINS=https://www.paperbanana.asia,https://paperbanana.asia,http://localhost:5173,http://127.0.0.1:5173,https://servicewechat.com,https://developers.weixin.qq.com

# Generate a long random string in production. Never commit the real value.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Current setup uses a Sealos gateway domain and paperbanana.asia frontend,
# so cross-site cookies need SameSite=None.
COOKIE_SAME_SITE=none

# If the gateway is later moved to api.paperbanana.asia, this can be enabled
# to share auth cookies across paperbanana.asia subdomains.
COOKIE_DOMAIN=

# MongoDB used by Better Auth for users, accounts, and sessions.
MONGODB_URI=mongodb://user:password@host:27017/paperbanana
MONGODB_DB=paperbanana

# Existing Laf PaperBanana function.
LAF_API_URL=https://sdswgya641.sealoshzh.site/paperbanana-api

# Set the same value in Laf PAPERBANANA_GATEWAY_TOKEN when you want to block direct public writes.
PAPERBANANA_GATEWAY_TOKEN=replace-with-shared-gateway-token
