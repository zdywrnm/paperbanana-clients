# ============================================
# PaperBanana Desktop 环境变量模板
# ============================================
# 桌面应用启动时加载的 URL
#
# 默认值:https://paperbanana.asia/ (生产环境线上前端)
# 开发时:可以改成本地 dev server,例如:
#   PAPERBANANA_DESKTOP_URL=http://localhost:5173
# ============================================

PAPERBANANA_DESKTOP_URL=https://paperbanana.asia/
