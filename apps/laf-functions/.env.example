# ============================================
# PaperBanana Laf 云函数环境变量模板
# ============================================
# 只写变量名和示例,不要提交真实密钥。

# 管理端查看任务记录使用的 Token
ADMIN_TOKEN=

# Laf 云存储 bucket 名称
PAPERBANANA_BUCKET=paperbanana

# 单次任务最多候选图数量
PAPERBANANA_MAX_CANDIDATES=3

# 单张候选图最多评审轮数
PAPERBANANA_MAX_CRITIC_ROUNDS=2

# SVG 参考图服务端栅格化宽度，范围会被限制在 320-1536
PAPERBANANA_SVG_REFERENCE_RASTER_WIDTH=1024
