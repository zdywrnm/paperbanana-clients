# ============================================
# PaperBanana Laf 云函数环境变量模板
# ============================================
# 只写变量名和示例,不要提交真实密钥。

# 管理端查看任务记录使用的 Token
ADMIN_TOKEN=

# 网关共享密钥。必须与 auth-gateway 的 PAPERBANANA_GATEWAY_TOKEN 设为同一个随机长串。
# 设置后,依赖调用方身份的动作(userJobs / createJob / refineImage /
# submitFeedback / getJob / prepareReferenceUpload)只接受携带该 token 的网关请求,
# 或带 ADMIN_TOKEN 的管理员请求;直连 Laf、伪造 userId 会被拒(401)。
# 留空 = 不强制(向后兼容);要真正关闭越权(IDOR),两端都必须配置并保持一致。
PAPERBANANA_GATEWAY_TOKEN=

# Laf 云存储 bucket 名称
PAPERBANANA_BUCKET=paperbanana

# 单次任务最多候选图数量
PAPERBANANA_MAX_CANDIDATES=3

# 单张候选图最多评审轮数
PAPERBANANA_MAX_CRITIC_ROUNDS=2

# SVG 参考图服务端栅格化宽度，范围会被限制在 320-1536
PAPERBANANA_SVG_REFERENCE_RASTER_WIDTH=1024
