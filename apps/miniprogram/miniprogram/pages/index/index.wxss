.example-panel {
  background: rgba(246, 242, 232, 0.72);
}

.example-panel-head,
.guide-title {
  color: #171513;
  font-size: 25rpx;
  font-weight: 780;
}

.example-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.example-card {
  display: grid;
  align-content: start;
  gap: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  background: rgba(255, 255, 251, 0.88);
}

.example-label {
  justify-self: start;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #77510b;
  background: #fff3d2;
  border: 1rpx solid #ead28d;
  font-size: 20rpx;
  font-weight: 760;
}

.example-title {
  color: #171513;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 780;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.example-hint {
  color: #68706d;
  font-size: 20rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.mode-field {
  margin-top: 18rpx;
}

.mode-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  padding: 6rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 16rpx;
  background: #f3f2ec;
}

.mode-switch button {
  display: grid;
  place-items: center;
  gap: 4rpx;
  min-width: 0;
  min-height: 74rpx;
  margin: 0;
  padding: 8rpx 6rpx;
  border-radius: 12rpx;
  color: #68706d;
  background: transparent;
  font-size: 25rpx;
  font-weight: 780;
  line-height: 1.2;
}

.mode-switch button.active {
  color: #ffffff;
  background: #315f51;
  box-shadow: 0 10rpx 22rpx rgba(38, 79, 67, 0.2);
}

.mode-switch text {
  color: inherit;
  font-size: 20rpx;
  font-weight: 680;
  line-height: 1.2;
  opacity: 0.72;
}

.field-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.field-row.single {
  grid-template-columns: 1fr;
}

.field-row .field {
  margin-top: 0;
}

.default-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 20rpx 0 0;
}

.default-summary text {
  min-height: 36rpx;
  padding: 7rpx 14rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 999rpx;
  color: #343230;
  background: #f3f2ec;
  font-size: 21rpx;
  font-weight: 650;
}

.advanced-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 16rpx;
  background: rgba(246, 242, 232, 0.62);
}

.advanced-title {
  color: #171513;
  font-size: 24rpx;
  font-weight: 780;
}

.advanced-grid,
.model-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.advanced-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.advanced-grid .field,
.model-grid .field {
  margin-top: 0;
}

.api-key-guide {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 16rpx;
  background: rgba(246, 242, 232, 0.62);
}

.guide-step {
  margin-top: 8rpx;
  color: #68706d;
  font-size: 22rpx;
  line-height: 1.5;
}

.method-textarea {
  height: 188rpx;
  min-height: 188rpx;
}

.plot-note {
  margin-top: 10rpx;
  padding: 12rpx 16rpx;
  border: 1rpx solid #ead28d;
  border-radius: 10rpx;
  background: #fff3d2;
  color: #77510b;
  font-size: 22rpx;
  line-height: 1.5;
}

.reference-upload-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.reference-upload-head > view {
  min-width: 0;
}

.reference-actions {
  display: flex;
  flex-shrink: 0;
  gap: 10rpx;
}

.reference-preview-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.reference-card {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  background: #fffffb;
}

.reference-thumb {
  width: 116rpx;
  height: 86rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 10rpx;
  background: #f3f2ec;
}

.reference-file-thumb {
  display: grid;
  place-items: center;
  width: 116rpx;
  height: 86rpx;
  border: 1rpx dashed #c8c2b6;
  border-radius: 10rpx;
  background: #f6f2e8;
  color: #315f51;
  font-size: 22rpx;
  font-weight: 760;
}

.reference-info {
  display: grid;
  gap: 6rpx;
  min-width: 0;
}

.reference-info text:first-child {
  overflow: hidden;
  color: #343230;
  font-size: 22rpx;
  font-weight: 720;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reference-info text:last-child {
  color: #68706d;
  font-size: 20rpx;
}

.reference-remove {
  margin: 0;
  padding: 0 12rpx;
  min-width: 76rpx;
  height: 50rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 10rpx;
  background: #f3f2ec;
  color: #8b5d08;
  font-size: 21rpx;
  line-height: 50rpx;
}

.reference-mode-panel {
  margin-top: 18rpx;
  padding: 16rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  background: rgba(246, 242, 232, 0.62);
}

.reference-mode-switch {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8rpx;
}

.reference-mode-switch button {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  min-width: 0;
  min-height: 66rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 12rpx;
  background: #fffffb;
  color: #343230;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.25;
  text-align: left;
  box-sizing: border-box;
}

.reference-mode-switch button.active {
  border-color: #315f51;
  background: #edf6ef;
  color: #315f51;
}

.reference-mode-switch button.disabled {
  color: #a89f91;
  background: #ede9df;
}

.job-badges {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.job-actions {
  display: flex;
  flex: none;
  gap: 10rpx;
}

/* 意见反馈悬浮按钮（与 web 端 feedback-fab 同款墨绿），可按住拖动。
   外层 movable-area 铺满视口但 pointer-events:none，只有按钮本身可交互。 */
.fab-area {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 90;
  pointer-events: none;
}

.feedback-fab {
  pointer-events: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 76rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(22, 72, 56, 0.84);
  background: #315f51;
  color: #fffffb;
  font-size: 24rpx;
  font-weight: 760;
  box-shadow: 0 12rpx 30rpx rgba(23, 21, 19, 0.24);
}
