/**app.wxss — PaperBanana 纸感设计系统（全页面与组件共享，组件需 styleIsolation: apply-shared）**/
page {
  min-height: 100vh;
  background: #f3f2ee;
  color: #171513;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

button::after {
  border: 0;
}

.page {
  height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fffffb 0%, #f3f2ee 360rpx);
}

.paper-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 22rpx;
  background: rgba(255, 255, 251, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(55, 46, 31, 0.08);
}

.brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.brand-logo {
  flex: none;
  width: 92rpx;
  height: 92rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 26rpx;
  background: #fffffb;
  box-shadow: 0 10rpx 26rpx rgba(55, 46, 31, 0.1);
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #171513;
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 800;
}

.brand-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.brand-tags text {
  min-height: 30rpx;
  padding: 5rpx 14rpx;
  border: 1rpx solid #ead28d;
  border-radius: 999rpx;
  color: #6b4807;
  background: #fff3d2;
  font-size: 20rpx;
  font-weight: 700;
}

.brand-tags text:first-child {
  color: #315f51;
  background: #edf5ef;
  border-color: #c8d8cc;
}

.auth-chip {
  flex: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  max-width: 260rpx;
  min-height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 999rpx;
  background: #fffffb;
  color: #343230;
  font-size: 23rpx;
  font-weight: 760;
  line-height: 64rpx;
}

.auth-chip.logged {
  color: #315f51;
  background: #edf6ef;
  border-color: #c8ddcd;
}

.auth-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #315f51;
}

.auth-email {
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip-button {
  margin: 0;
  padding: 0;
  color: #8b5d08;
  background: transparent;
  font-size: 22rpx;
  line-height: 1;
}

.status-row {
  display: flex;
  gap: 12rpx;
  padding: 22rpx 24rpx 0;
  flex-wrap: wrap;
}

.status-pill {
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 251, 0.86);
  color: #68706d;
  border: 1rpx solid #d9d6cc;
  font-size: 22rpx;
}

.status-pill.ok {
  color: #315f51;
  background: #e6f0e6;
  border-color: #c8d8cc;
}

.status-pill.warn {
  color: #8b5d08;
  background: #fff3d2;
  border-color: #ead28d;
}

.status-action {
  margin: 0;
  padding: 0 18rpx;
  min-height: 46rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 999rpx;
  background: #fffffb;
  color: #343230;
  font-size: 22rpx;
  font-weight: 720;
  line-height: 46rpx;
}

.section {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 22rpx;
  background: rgba(255, 255, 251, 0.94);
  box-shadow: 0 18rpx 48rpx rgba(55, 46, 31, 0.07);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.section-title {
  color: #171513;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-note {
  margin-top: 8rpx;
  color: #68706d;
  font-size: 23rpx;
  line-height: 1.5;
}

.field {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #343230;
  font-size: 24rpx;
  font-weight: 720;
}

.field-tip {
  margin-top: 10rpx;
  color: #68706d;
  font-size: 22rpx;
  line-height: 1.5;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  background: #fffffb;
  color: #171513;
  font-size: 26rpx;
}

.input,
.picker-value {
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
}

.input {
  line-height: normal;
}

.picker-value {
  line-height: 88rpx;
}

.picker-value.locked {
  color: #a89f91;
  background: #ede9df;
}

.textarea {
  height: 188rpx;
  min-height: 188rpx;
  max-height: 188rpx;
  padding: 18rpx 20rpx;
  line-height: 1.5;
}

.compact-field .field-label {
  margin-bottom: 8rpx;
  font-size: 22rpx;
}

.compact-input,
.compact-picker {
  min-height: 76rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  line-height: 76rpx;
}

.model-picker {
  height: auto;
  min-height: 76rpx;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  line-height: 1.35;
  white-space: normal;
}

.primary-button,
.secondary-button,
.login-card-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #171513;
  font-size: 27rpx;
  font-weight: 780;
  line-height: 82rpx;
  box-shadow: 0 12rpx 28rpx rgba(23, 21, 19, 0.16);
}

.primary-button {
  margin-top: 28rpx;
}

.primary-button[disabled] {
  background: #c9c0b2;
  box-shadow: none;
}

.secondary-button {
  min-height: 64rpx;
  margin-top: 16rpx;
  background: #315f51;
  font-size: 24rpx;
  line-height: 64rpx;
}

.text-button {
  margin: 18rpx 0 0;
  padding: 0;
  display: inline-flex;
  color: #8b5d08;
  background: transparent;
  font-size: 24rpx;
  font-weight: 760;
  line-height: 1.4;
}

.ghost-button {
  flex: none;
  margin: 0;
  padding: 0 18rpx;
  min-width: 96rpx;
  height: 58rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d9d6cc;
  background: #fffffb;
  color: #343230;
  font-size: 23rpx;
  line-height: 58rpx;
}

.submit-tip {
  margin-top: 14rpx;
  color: #68706d;
  font-size: 23rpx;
  text-align: center;
}

.status-badge,
.history-status {
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff3d2;
  color: #77510b;
  font-size: 22rpx;
  font-weight: 760;
}

.status-badge.succeeded,
.history-status.succeeded {
  color: #315f51;
  background: #e6f0e6;
}

.status-badge.failed,
.history-status.failed {
  color: #9f3a2d;
  background: #f5e4df;
}

.error-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f5e4df;
  color: #9f3a2d;
  font-size: 24rpx;
  line-height: 1.5;
}

.success-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #e6f0e6;
  color: #315f51;
  font-size: 24rpx;
  line-height: 1.5;
}

.result-grid,
.record-images {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.asset-card,
.record-asset-card {
  display: grid;
  gap: 10rpx;
  padding: 12rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 16rpx;
  background: #fffffb;
}

.result-image,
.record-images image {
  width: 100%;
  border-radius: 14rpx;
  background: #f3f2ec;
  border: 1rpx solid #d9d6cc;
}

.record-reference-image {
  height: 156rpx;
}

.record-result-image {
  min-height: 120rpx;
}

.file-asset {
  display: grid;
  align-content: center;
  gap: 10rpx;
  min-height: 180rpx;
  padding: 22rpx;
  border: 1rpx dashed #c8c2b6;
  border-radius: 14rpx;
  background: #f3f2ec;
  box-sizing: border-box;
}

.file-asset.compact {
  min-height: 132rpx;
  padding: 18rpx;
}

.file-asset-format {
  justify-self: start;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: #edf6ef;
  color: #315f51;
  font-size: 20rpx;
  font-weight: 760;
}

.file-asset-name {
  color: #343230;
  font-size: 23rpx;
  font-weight: 720;
  line-height: 1.35;
  word-break: break-all;
}

.asset-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.asset-actions text {
  min-width: 0;
  color: #68706d;
  font-size: 21rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-actions button,
.record-asset-card button {
  flex: none;
  margin: 0;
  padding: 0 14rpx;
  min-width: 118rpx;
  height: 52rpx;
  border: 1rpx solid #c8ddcd;
  border-radius: 10rpx;
  background: #edf6ef;
  color: #315f51;
  font-size: 21rpx;
  font-weight: 720;
  line-height: 52rpx;
}

.empty-state {
  display: grid;
  place-items: center;
  gap: 8rpx;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx dashed #c8c2b6;
  border-radius: 14rpx;
  background: #f3f2ec;
  color: #68706d;
  font-size: 25rpx;
  text-align: center;
}

.empty-state text {
  font-size: 22rpx;
}

.history-item,
.job-record-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 16rpx;
  background: #fffffb;
}

.history-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.history-main {
  min-width: 0;
}

.history-title,
.job-record-title {
  color: #171513;
  font-size: 25rpx;
  font-weight: 760;
  line-height: 1.38;
}

.history-meta,
.job-record-time {
  margin-top: 7rpx;
  color: #68706d;
  font-size: 22rpx;
}

.job-panel,
.account-row,
.job-record-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.job-panel {
  margin-top: 20rpx;
}

.job-record-card {
  display: grid;
  gap: 14rpx;
}

.job-record-meta,
.job-models {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.job-record-meta text,
.job-models text {
  min-width: 0;
  color: #68706d;
  font-size: 21rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-models {
  grid-template-columns: 1fr;
  padding: 16rpx;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  background: #f3f2ec;
}

.job-models view {
  display: grid;
  gap: 4rpx;
}

.job-models text:first-child {
  color: #8a9089;
  font-weight: 760;
}

.job-models text:last-child {
  color: #343230;
}

.job-record-error {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #ead1ca;
  border-radius: 12rpx;
  background: #f8ebe7;
  color: #9f3a2d;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.job-prompt-preview {
  max-height: 156rpx;
  overflow: hidden;
  padding: 16rpx;
  color: #343230;
  background: #f3f2ec;
  border: 1rpx solid #d9d6cc;
  border-radius: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.record-asset-section {
  display: grid;
  gap: 10rpx;
}

.record-asset-title {
  color: #343230;
  font-size: 23rpx;
  font-weight: 760;
}

.record-asset-card.result {
  margin-top: 0;
}

.login-required-card {
  padding: 22rpx;
  border: 1rpx solid #d9d6cc;
  border-left: 6rpx solid #c5a14e;
  border-radius: 16rpx;
  background: rgba(255, 255, 251, 0.78);
}

.login-card-title {
  color: #171513;
  font-size: 27rpx;
  font-weight: 780;
}

.login-card-note {
  margin-top: 10rpx;
  color: #68706d;
  font-size: 23rpx;
  line-height: 1.5;
}

.login-card-button {
  width: 220rpx;
  min-height: 66rpx;
  margin: 20rpx 0 0;
  font-size: 24rpx;
  line-height: 66rpx;
}

.account-row {
  padding: 18rpx;
  border: 1rpx solid #c8ddcd;
  border-radius: 16rpx;
  background: #edf6ef;
}

.account-row text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #315f51;
  font-size: 24rpx;
  font-weight: 760;
}

.footer-space {
  height: 48rpx;
}
